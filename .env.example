# ─────────────────────────────────────────────────────────────
#  Sakthivel Mayilsamy — Portfolio Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git. Only commit .env.example
# ─────────────────────────────────────────────────────────────

# ── CONTACT FORM (Web3Forms) ──────────────────────────────────
# Get your key at https://web3forms.com
# Safe to expose publicly — domain-locked by Web3Forms
WEB3FORMS_ACCESS_KEY="58e363d8-0dc9-4acd-8068-3c93bd278ca6"

# ── EMAIL SERVICE (if using SendGrid / Mailgun) ───────────────
SENDGRID_API_KEY=your_sendgrid_key_here
MAILGUN_API_KEY=your_mailgun_key_here
MAILGUN_DOMAIN=your_mailgun_domain_here

# ── AWS CREDENTIALS ───────────────────────────────────────────
# Never put these in frontend code. Use IAM roles on EC2/Lambda.
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ca-central-1
S3_BUCKET_NAME=your_bucket_name_here

# ── DATABASE ──────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@host:5432/dbname
MYSQL_URL=mysql://username:password@host:3306/dbname
REDIS_URL=redis://localhost:6379/0

# ── FLASK / DJANGO ────────────────────────────────────────────
SECRET_KEY=generate_a_long_random_string_here
FLASK_ENV=development
DEBUG=True

# ── THIRD PARTY APIs ──────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
